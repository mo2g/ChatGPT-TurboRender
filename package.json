{
  "name": "chatgpt-turborender",
  "version": "0.1.7",
  "private": true,
  "description": "A Chromium-first extension that keeps long ChatGPT conversations responsive by parking cold DOM nodes.",
  "packageManager": "pnpm@9.14.2",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build -b chrome",
    "build:edge": "wxt build -b edge",
    "build:firefox": "wxt build -b firefox",
    "package:chrome": "node ./scripts/package-browser-release.mjs chrome",
    "package:edge": "node ./scripts/package-browser-release.mjs edge",
    "package:firefox": "node ./scripts/package-browser-release.mjs firefox",
    "package:all": "pnpm package:chrome && pnpm package:edge && pnpm package:firefox",
    "chrome:preflight": "node ./scripts/publish-stores.mjs -- --check-chrome",
    "release:publish-stores": "node ./scripts/publish-stores.mjs",
    "debug:mcp-chrome": "node ./scripts/debug-mcp-chrome.mjs",
    "test": "pnpm test:unit",
    "test:all": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.0",
    "crx": "^5.0.1",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "web-ext": "^10.0.0",
    "wxt": "^0.20.20"
  }
}
